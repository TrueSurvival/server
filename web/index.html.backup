<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="MC.SODOPS.UZ - Premium Minecraft Server Portal">
    <meta name="theme-color" content="#00f0ff">
    <title>MC.SODOPS.UZ - Premium Minecraft Server</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800;900&family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }
        
        h1, h2, h3, h4, h5, h6 {
            font-family: 'Montserrat', sans-serif;
        }
        
        :root {
            --nether-black: #0a0e27;
            --deep-slate: #12131a;
            --charcoal: #1a1b2e;
            --diamond-blue: #00f0ff;
            --gold: #ffaa00;
            --emerald: #2ecc71;
            --text-light: #e8eaed;
            --text-muted: #a0a5b8;
        }
        
        body {
            background: linear-gradient(135deg, var(--nether-black) 0%, var(--deep-slate) 50%, #0f1025 100%);
            color: var(--text-light);
            overflow-x: hidden;
        }
        
        /* Glassmorphism Background */
        .glass {
            background: rgba(18, 19, 26, 0.6);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 240, 255, 0.1);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }
        
        .glass-light {
            background: rgba(26, 27, 46, 0.4);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(0, 240, 255, 0.05);
        }
        
        /* Neon Glow Effects */
        .neon-glow {
            box-shadow: 0 0 20px rgba(0, 240, 255, 0.5);
        }
        
        .glow-text {
            text-shadow: 0 0 20px rgba(0, 240, 255, 0.5);
        }
        
        .gold-glow {
            box-shadow: 0 0 20px rgba(255, 170, 0, 0.4);
        }
        
        /* Gradient Borders */
        .gradient-border {
            background: linear-gradient(var(--nether-black), var(--deep-slate)) padding-box,
                        linear-gradient(135deg, var(--diamond-blue), var(--emerald)) border-box;
            border: 2px solid transparent;
        }
        
        /* Smooth Transitions */
        .transition-smooth {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        /* Minecraft Premium Button */
        .btn-premium {
            background: linear-gradient(135deg, var(--diamond-blue), #00d9ff);
            box-shadow: 0 0 20px rgba(0, 240, 255, 0.3), inset 0 0 20px rgba(255, 255, 255, 0.1);
            position: relative;
            overflow: hidden;
        }
        
        .btn-premium::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.6s;
        }
        
        .btn-premium:hover::before {
            left: 100%;
        }
        
        .btn-premium:hover {
            box-shadow: 0 0 40px rgba(0, 240, 255, 0.6), inset 0 0 30px rgba(255, 255, 255, 0.2);
            transform: translateY(-3px);
        }
        
        /* Outlined Button */
        .btn-outlined {
            border: 2px solid var(--diamond-blue);
            position: relative;
            overflow: hidden;
        }
        
        .btn-outlined::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: rgba(0, 240, 255, 0.1);
            transition: left 0.4s;
        }
        
        .btn-outlined:hover::before {
            left: 0;
        }
        
        .btn-outlined:hover {
            box-shadow: 0 0 20px rgba(0, 240, 255, 0.3);
        }
        
        /* Premium Card */
        .card-premium {
            background: rgba(18, 19, 26, 0.5);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(0, 240, 255, 0.1);
            border-radius: 24px;
            position: relative;
            overflow: hidden;
        }
        
        .card-premium::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--diamond-blue), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        .card-premium:hover::before {
            opacity: 1;
        }
        
        .card-premium:hover {
            border-color: rgba(0, 240, 255, 0.2);
            box-shadow: 0 0 30px rgba(0, 240, 255, 0.1);
            transform: translateY(-5px);
        }
        
        /* Floating Animation */
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }
        
        .float-animation {
            animation: float 6s ease-in-out infinite;
        }
        
        /* Pulse Animation */
        @keyframes pulse-glow {
            0%, 100% { 
                box-shadow: 0 0 20px rgba(0, 240, 255, 0.3);
            }
            50% { 
                box-shadow: 0 0 40px rgba(0, 240, 255, 0.6);
            }
        }
        
        .pulse-glow {
            animation: pulse-glow 3s ease-in-out infinite;
        }
        
        /* Gradient Text */
        .text-gradient {
            background: linear-gradient(135deg, var(--diamond-blue) 0%, var(--gold) 50%, var(--emerald) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        /* Minecraft Grid Background */
        .minecraft-bg {
            position: relative;
            overflow: hidden;
        }
        
        .minecraft-bg::before {
            content: '';
            position: absolute;
            width: 200%;
            height: 200%;
            background-image: 
                repeating-linear-gradient(
                    0deg,
                    transparent,
                    transparent 2px,
                    rgba(0, 240, 255, 0.03) 2px,
                    rgba(0, 240, 255, 0.03) 4px
                ),
                repeating-linear-gradient(
                    90deg,
                    transparent,
                    transparent 2px,
                    rgba(0, 240, 255, 0.03) 2px,
                    rgba(0, 240, 255, 0.03) 4px
                );
            animation: drift 20s linear infinite;
            z-index: 0;
        }
        
        @keyframes drift {
            0% { transform: translate(0, 0); }
            100% { transform: translate(100px, 100px); }
        }
        
        .minecraft-bg > * {
            position: relative;
            z-index: 1;
        }
        
        /* Feature Icons */
        .icon-box {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, rgba(0, 240, 255, 0.2), rgba(46, 204, 113, 0.2));
            border-radius: 16px;
            border: 1px solid rgba(0, 240, 255, 0.3);
            font-size: 28px;
        }
        
        /* Status Indicator */
        .status-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--emerald);
            box-shadow: 0 0 10px rgba(46, 204, 113, 0.8);
            animation: pulse 2s ease-in-out infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .minecraft-bg::before {
                display: none;
            }
        }
    </style>
</head>
<body class="minecraft-bg">
    <!-- Navigation Header -->
    <header class="fixed top-0 w-full z-50 glass">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <div class="text-2xl">⛏️</div>
                <h1 class="text-xl font-bold text-gradient">MC.SODOPS.UZ</h1>
            </div>
            <ul class="hidden md:flex gap-8 items-center">
                <li><a href="#home" class="nav-link text-text-muted hover:text-diamond-blue transition-smooth">Home</a></li>
                <li><a href="#features" class="nav-link text-text-muted hover:text-diamond-blue transition-smooth">Features</a></li>
                <li><a href="#dashboard" class="nav-link text-text-muted hover:text-diamond-blue transition-smooth">Dashboard</a></li>
                <li><button id="themeToggle" class="glass px-4 py-2 rounded-lg text-sm border border-diamond-blue/30 hover:border-diamond-blue/60 transition-smooth">🌙 Dark</button></li>
            </ul>
        </nav>
    </header>

    <!-- Hero Section -->
    <section id="home" class="min-h-screen flex items-center justify-center pt-20 px-4">
        <div class="max-w-5xl mx-auto text-center">
            <!-- Floating Badge -->
            <div class="mb-8 inline-block glass px-6 py-3 rounded-full border border-diamond-blue/30">
                <div class="flex items-center gap-2">
                    <span class="status-dot"></span>
                    <span class="text-sm text-diamond-blue font-medium">Server Online • 24/7 Uptime</span>
                </div>
            </div>

            <!-- Main Title -->
            <h1 class="text-6xl md:text-8xl font-black font-montserrat mb-6 text-gradient glow-text leading-tight">
                Minecraft Server Portal
            </h1>

            <!-- Subtitle -->
            <p class="text-xl md:text-2xl text-text-muted mb-12 max-w-2xl mx-auto leading-relaxed">
                Real-time monitoring, live dashboard, and advanced server management. Professional hosting from the Nether to the End.
            </p>

            <!-- CTA Buttons -->
            <div class="flex flex-col sm:flex-row gap-6 justify-center mb-16">
                <a href="dashboard.html" class="btn-premium px-8 py-4 rounded-lg font-semibold text-nether-black transition-smooth group inline-block">
                    <span class="relative z-10 flex items-center justify-center gap-2">
                        📊 Go to Dashboard
                        <svg class="w-5 h-5 group-hover:translate-x-2 transition-smooth" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                        </svg>
                    </span>
                </a>
                <button class="btn-outlined px-8 py-4 rounded-lg font-semibold text-diamond-blue transition-smooth group">
                    <span class="flex items-center justify-center gap-2">
                        📚 Documentation
                        <svg class="w-5 h-5 group-hover:translate-x-1 transition-smooth" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </span>
                </button>
            </div>

            <!-- Stats Bar -->
            <div class="grid grid-cols-3 gap-4 md:gap-8 max-w-2xl mx-auto">
                <div class="glass px-6 py-4 rounded-xl border border-diamond-blue/20">
                    <div class="text-3xl font-bold text-diamond-blue">1</div>
                    <div class="text-sm text-text-muted mt-2">Players Online</div>
                </div>
                <div class="glass px-6 py-4 rounded-xl border border-gold/20">
                    <div class="text-3xl font-bold text-gold">20</div>
                    <div class="text-sm text-text-muted mt-2">Max Players</div>
                </div>
                <div class="glass px-6 py-4 rounded-xl border border-emerald/20">
                    <div class="text-3xl font-bold text-emerald">99.9%</div>
                    <div class="text-sm text-text-muted mt-2">Uptime</div>
                </div>
            </div>
        </div>

        <!-- Scroll Indicator -->
        <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-bounce">
            <svg class="w-6 h-6 text-diamond-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-24 px-4">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-5xl md:text-6xl font-black font-montserrat mb-4 text-gradient">Premium Features</h2>
                <p class="text-xl text-text-muted max-w-2xl mx-auto">Everything you need to manage your Minecraft server like a pro</p>
            </div>

            <!-- Feature Cards Grid -->
            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Card 1 -->
                <div class="card-premium p-8 group">
                    <div class="icon-box mb-6 group-hover:scale-110 transition-smooth">🟢</div>
                    <h3 class="text-xl font-bold mb-3 text-white">Real-time Status</h3>
                    <p class="text-text-muted text-sm leading-relaxed">Live server monitoring with instant updates every 5 seconds. Always know what's happening.</p>
                </div>

                <!-- Card 2 -->
                <div class="card-premium p-8 group">
                    <div class="icon-box mb-6 group-hover:scale-110 transition-smooth">📋</div>
                    <h3 class="text-xl font-bold mb-3 text-white">Live Logs</h3>
                    <p class="text-text-muted text-sm leading-relaxed">Stream server logs in real-time with syntax highlighting and advanced filtering options.</p>
                </div>

                <!-- Card 3 -->
                <div class="card-premium p-8 group">
                    <div class="icon-box mb-6 group-hover:scale-110 transition-smooth">💾</div>
                    <h3 class="text-xl font-bold mb-3 text-white">Memory Tracking</h3>
                    <p class="text-text-muted text-sm leading-relaxed">Monitor RAM usage, CPU load, and world sizes. Optimize your server performance instantly.</p>
                </div>

                <!-- Card 4 -->
                <div class="card-premium p-8 group">
                    <div class="icon-box mb-6 group-hover:scale-110 transition-smooth">🎨</div>
                    <h3 class="text-xl font-bold mb-3 text-white">Theme Toggle</h3>
                    <p class="text-text-muted text-sm leading-relaxed">Switch between dark and light themes. Eye-friendly interface for day and night sessions.</p>
                </div>

                <!-- Card 5 -->
