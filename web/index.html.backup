                        <span class="text-sm text-emerald">All Systems Online</span>
                    </div>
                    <p class="text-text-muted text-sm mt-2">99.9% Uptime</p>
                </div>
            </div>

            <div class="border-t border-diamond-blue/10 pt-8 text-center text-text-muted text-sm">
                <p>&copy; 2025-2026 MC.SODOPS.UZ | Built with ❤️ by Sodiq | Premium Minecraft Server Portal</p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script>
        // Smooth scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });

        // Theme toggle
        document.getElementById('themeToggle').addEventListener('click', function() {
            document.documentElement.classList.toggle('dark');
            this.textContent = document.documentElement.classList.contains('dark') ? '☀️ Light' : '🌙 Dark';
        });

        // Copy to clipboard
        document.querySelectorAll('[class*="font-mono"]').forEach(el => {
            el.addEventListener('click', () => {
                navigator.clipboard.writeText(el.textContent);
                const btn = el.closest('.card-premium')?.querySelector('button');
                if (btn) {
                    btn.textContent = '✅ Copied!';
                    setTimeout(() => btn.textContent = '📋 Copy Address', 2000);
                }
            });
        });

        // Real-time updates (would connect to actual API)
        setInterval(() => {
            // Update player count, memory, etc
            console.log('Updating server status...');
        }, 5000);
    </script>
</body>
</html>
