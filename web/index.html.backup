                    <div class="icon-box mb-6 group-hover:scale-110 transition-smooth">⚡</div>
                    <h3 class="text-xl font-bold mb-3 text-white">Performance Metrics</h3>
                    <p class="text-text-muted text-sm leading-relaxed">Detailed analytics on server performance. TPS, RAM, CPU - everything at your fingertips.</p>
                </div>

                <!-- Card 7 -->
                <div class="card-premium p-8 group">
                    <div class="icon-box mb-6 group-hover:scale-110 transition-smooth">📡</div>
                    <h3 class="text-xl font-bold mb-3 text-white">API Integration</h3>
                    <p class="text-text-muted text-sm leading-relaxed">RESTful API endpoints for custom integrations. Build your own tools on top of our platform.</p>
                </div>

                <!-- Card 8 -->
                <div class="card-premium p-8 group">
                    <div class="icon-box mb-6 group-hover:scale-110 transition-smooth">🔐</div>
                    <h3 class="text-xl font-bold mb-3 text-white">Security First</h3>
                    <p class="text-text-muted text-sm leading-relaxed">Enterprise-grade security with RCON encryption. Your server data is always protected.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Server Info Section -->
    <section class="py-24 px-4 bg-gradient-to-b from-transparent via-nether-black/50 to-transparent">
        <div class="max-w-7xl mx-auto">
            <div class="grid md:grid-cols-2 gap-12 items-center">
